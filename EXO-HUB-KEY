<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EXO HUB | Key System</title>
    <style>
        body {
            background-color: #0a0a0a;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .container {
            background: #111;
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            border: 2px solid #8a2be2;
            box-shadow: 0 0 25px rgba(138, 43, 226, 0.4);
            width: 320px;
        }
        h1 { font-size: 28px; letter-spacing: 4px; margin-bottom: 5px; }
        .purple { color: #8a2be2; text-shadow: 0 0 10px #8a2be2; }
        .status { font-size: 11px; color: #666; text-transform: uppercase; margin-bottom: 25px; }
        .key-box {
            background: #000;
            padding: 15px;
            border-radius: 8px;
            font-size: 20px;
            color: #8a2be2;
            font-weight: bold;
            border: 1px dashed #444;
            margin-bottom: 20px;
        }
        button {
            background: #8a2be2;
            color: white;
            border: none;
            padding: 12px;
            width: 100%;
            border-radius: 6px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        button:hover { background: #a052ee; transform: scale(1.02); }
    </style>
</head>
<body>
    <div class="container">
        <h1>EXO <span class="purple">HUB</span></h1>
        <div class="status">System Online</div>
        <div class="key-box" id="keyDisplay">CLICK TO GET KEY</div>
        <button onclick="copyKey()">GET KEY</button>
    </div>

    <script>
        function copyKey() {
            const key = "EXO-ON-TOP";
            document.getElementById('keyDisplay').innerText = key;
            navigator.clipboard.writeText(key);
            alert("Key Copied: " + key);
        }
    </script>
</body>
</html>
