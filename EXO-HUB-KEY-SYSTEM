<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EXO HUB | Key System</title>
    <style>
        /* Modern Dark Theme Design */
        body {
            background-color: #0d0d0d;
            color: #ffffff;
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        .container {
            background: rgba(20, 20, 20, 0.95);
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            border: 2px solid #8a2be2; /* Neon Purple Border */
            box-shadow: 0 0 30px rgba(138, 43, 226, 0.3);
            width: 350px;
        }

        .logo-text {
            font-size: 32px;
            font-weight: 800;
            letter-spacing: 5px;
            margin-bottom: 5px;
            text-transform: uppercase;
        }

        .hub-text {
            color: #8a2be2;
            text-shadow: 0 0 10px #8a2be2;
        }

        .status {
            font-size: 10px;
            color: #b0b0b0;
            letter-spacing: 3px;
            margin-bottom: 30px;
            text-transform: uppercase;
        }

        .key-display {
            background: #000000;
            padding: 20px;
            margin: 20px 0;
            border-radius: 12px;
            font-family: 'Courier New', Courier, monospace;
            font-size: 20px;
            border: 1px solid #333;
            color: #8a2be2;
            font-weight: bold;
            letter-spacing: 2px;
        }

        button {
            background: #8a2be2;
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            width: 100%;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        button:hover {
            background: #a052ee;
            box-shadow: 0 0 15px #8a2be2;
            transform: translateY(-2px);
        }

        .footer {
            margin-top: 20px;
            font-size: 12px;
            color: #555;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="logo-text">EXO <span class="hub-text">HUB</span></div>
        <div class="status">System Active</div>
        
        <p style="font-size: 14px; color: #ccc;">Your temporary access key:</p>
        
        <div class="key-display" id="keyText">EXO-XXXXX</div>
        
        <button onclick="generateKey()">Get Key</button>
        
        <div class="footer">
            © 2026 EXO HUB | Universal Access
        </div>
    </div>

    <script>
        function generateKey() {
            // Ito ay mag-ge-generate ng random key tuwing iki-click
            const chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789";
            let randomString = "";
            for (let i = 0; i < 10; i++) {
                randomString += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            
            const finalKey = "EXO-" + randomString;
            document.getElementById('keyText').innerText = finalKey;
            
            // Auto-copy to clipboard
            navigator.clipboard.writeText(finalKey);
            alert("Key Copied: " + finalKey);
        }
    </script>
</body>
</html>
